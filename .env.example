# Supabase project credentials (free tier is sufficient).
# Reuses the same room/realtime backend as the StellarBurst project.
# Create / open a project at https://supabase.com, run supabase/schema.sql in the
# SQL editor, then copy these from Project Settings -> API.
# The publishable key (sb_publishable_...) is browser-safe by design.
# NEVER put a service_role or secret key in these NEXT_PUBLIC_ variables.
#
# If these are left empty, the game runs in LOCAL mode (single device,
# pass-and-play + CPU) so you can develop without a backend.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
